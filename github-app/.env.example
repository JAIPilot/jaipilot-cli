GITHUB_APP_ID=123456
GITHUB_WEBHOOK_SECRET=replace-with-random-secret
# Option 1: load private key from file path
GITHUB_APP_PRIVATE_KEY_PATH=./private-key.pem
# Option 2: inline private key (newline escaped)
# GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n

PORT=3000
WEBHOOK_PATH=/api/webhook

# Action reference injected into target repo workflow YAML.
JAIPILOT_ACTION_REPO=skrcode/jaipilot-cli
JAIPILOT_ACTION_REF=action-v1
JAIPILOT_WORKFLOW_PATH=.github/workflows/jaipilot-generate.yml
JAIPILOT_WORKFLOW_COMMIT_MESSAGE=chore: add JAIPilot generate workflow

# Behavior flags.
JAIPILOT_BOOTSTRAP_ON_INSTALL=true
JAIPILOT_BOOTSTRAP_ON_PULL_REQUEST=true
JAIPILOT_DISPATCH_ON_INSTALL=false
JAIPILOT_DISPATCH_ON_PULL_REQUEST=false

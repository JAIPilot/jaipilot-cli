{
  "name": "jaipilot-vscode",
  "displayName": "JAIPilot – One-Click AI Agent for Java Unit Testing",
  "description": "JAIPilot – One-Click AI Agent for Java Unit Testing, AI-Powered Unit Tests for Java — generate, run, and fix tests automatically inside VSCode.",
  "version": "0.0.5",
  "publisher": "jaipilot",
  "license": "MIT",
  "homepage": "https://jaipilot.com",
  "bugs": {
    "url": "https://github.com/JAIPilot/jaipilot-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JAIPilot/jaipilot-cli.git"
  },
  "icon": "media/icon.png",
  "keywords": [
    "java",
    "junit",
    "unit-test",
    "testing",
    "ai",
    "productivity",
    "jaipilot"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onCommand:jaipilot.generateForJavaClass",
    "onCommand:jaipilot.cancelCurrentRun"
  ],
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "qna": "https://discord.gg/BE579j7mKH",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jaipilot.generateForJavaClass",
        "title": "Generate Tests with JAIPilot"
      },
      {
        "command": "jaipilot.cancelCurrentRun",
        "title": "Cancel JAIPilot Generation"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "jaipilot.cancelCurrentRun",
          "when": "jaipilot.runInProgress"
        }
      ],
      "explorer/context": [
        {
          "command": "jaipilot.generateForJavaClass",
          "when": "resourceScheme == file && resourceExtname == .java && !(resourceFilename =~ /(Test|Tests|IT)\\.java$/)",
          "group": "navigation@90"
        }
      ],
      "editor/context": [
        {
          "command": "jaipilot.generateForJavaClass",
          "when": "resourceScheme == file && editorLangId == java && !(resourceFilename =~ /(Test|Tests|IT)\\.java$/)",
          "group": "navigation@90"
        }
      ]
    },
    "configuration": {
      "title": "JAIPilot",
      "properties": {
        "jaipilot.cliPath": {
          "type": "string",
          "default": "jaipilot",
          "description": "Path to the JAIPilot CLI executable."
        },
        "jaipilot.additionalGenerateArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra arguments to append before the class path in `jaipilot generate`."
        }
      }
    }
  },
  "scripts": {
    "clean": "rm -rf dist *.vsix",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "package:pre-release": "vsce package --pre-release",
    "publish": "vsce publish",
    "publish:pre-release": "vsce publish --pre-release"
  },
  "devDependencies": {
    "@types/node": "^22.15.31",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.8.3"
  }
}
